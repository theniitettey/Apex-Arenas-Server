<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome to Apex Arenas</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f3f4f6;">
  <table role="presentation" style="width: 100%; border-collapse: collapse;">
    <tr>
      <td align="center" style="padding: 40px 0;">
        <table role="presentation" style="width: 600px; border-collapse: collapse; background-color: #ffffff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
          <!-- Header -->
          <tr>
            <td style="padding: 40px 40px 20px; text-align: center; background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%); border-radius: 8px 8px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: bold;">🎮 Welcome to Apex Arenas!</h1>
            </td>
          </tr>
          
          <!-- Content -->
          <tr>
            <td style="padding: 40px;">
              <h2 style="margin: 0 0 20px; color: #1f2937; font-size: 24px;">You're all set, {{user_name}}! 🎉</h2>
              
              <p style="margin: 0 0 20px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                Your email has been verified and your account is ready. Welcome to the ultimate mobile gaming tournament platform!
              </p>
              
              <div style="background-color: #f3e8ff; border-radius: 8px; padding: 20px; margin: 0 0 30px;">
                <h3 style="margin: 0 0 15px; color: #7c3aed; font-size: 18px;">🚀 Get Started</h3>
                <ul style="margin: 0; padding: 0 0 0 20px; color: #4b5563; font-size: 14px; line-height: 1.8;">
                  <li>Complete your gaming profile</li>
                  <li>Browse upcoming tournaments</li>
                  <li>Join or create a team</li>
                  <li>Enable 2FA for added security</li>
                </ul>
              </div>
              
              <p style="margin: 0 0 20px; color: #4b5563; font-size: 16px; line-height: 1.6;">
                Your username: <strong style="color: #7c3aed;">@{{username}}</strong>
              </p>
              
              <p style="margin: 0; color: #4b5563; font-size: 16px; line-height: 1.6;">
                Good luck and have fun competing! 🏆
              </p>
            </td>
          </tr>
          
          <!-- Footer -->
          <tr>
            <td style="padding: 30px 40px; background-color: #f9fafb; border-radius: 0 0 8px 8px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0 0 10px; color: #6b7280; font-size: 12px; text-align: center;">
                Questions? Contact us at <a href="mailto:{{support_email}}" style="color: #7c3aed; text-decoration: none;">{{support_email}}</a>
              </p>
              <p style="margin: 0; color: #9ca3af; font-size: 12px; text-align: center;">
                © {{current_year}} Apex Arenas. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>