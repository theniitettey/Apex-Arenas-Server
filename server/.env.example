# Server Configs
NODE_ENV=development
PORT=5000
API_VERSION=v1
SERVICE_NAME=APEX_API_SERVICE
SERVICE_VERSION=1.0.0

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Verification settings
MAX_DOCUMENT_SIZE_BYTES=5242880
MAX_RESUBMISSION_COUNT=3

# MongoDB Configs
MONGODB_URI=
MONGODB_DB_NAME=auth_service
MONGODB_POOL_SIZE=10
MONGODB_CONNECTION_TIMEOUT=30000

# Redis Configs
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_OTP=600
REDIS_TTL_SESSION=86400
REDIS_TLS=false
IDEMPOTENCY_KEY_TTL=3600
LOCKOUT_WINDOW_MINUTES=900

# JWT & Security Configs
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=7d
JWT_ADMIN_ACCESS_SECRET=
JWT_ADMIN_ACCESS_EXPIRES_IN=600
JWT_ADMIN_REFRESH_EXPIRES_IN=1d
JWT_ISSUER_USERS=apex_service
JWT_ISSUER_ADMIN=apex_admin_service
INTERNAL_SERVICE_SECRET=
BCRYPT_ROUNDS=12
ADMIN_SECRET_KEY=
ADMIN_EMAILS=

# Lockout Configuration
LOCKOUT_MAX_ATTEMPTS_USER=5
LOCKOUT_MAX_ATTEMPTS_ADMIN=3
LOCKOUT_DURATION_USER_MINUTES=30
LOCKOUT_DURATION_ADMIN_MINUTES=60

# Session Configuration
MAX_SESSIONS_PER_USER=1
MAX_SESSIONS_PER_ADMIN=1

# Token Blacklist
TOKEN_BLACKLIST_TTL_SECONDS=900

# Password Configuration
PASSWORD_HISTORY_COUNT=5
PASSWORD_MIN_STRENGTH_SCORE=60
HIBP_API_ENABLED=true
HIBP_API_TIMEOUT_MS=5000

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_SECONDS=60
OTP_LOCKOUT_MINUTES=15

# IP Blocking
IP_BLOCK_DURATION_SECONDS=3600
IP_SUSPICIOUS_THRESHOLD=3
IP_FAILED_ATTEMPTS_THRESHOLD=10
IP_AUTO_BLOCK_FAILED_THRESHOLD=20

# Audit & Cleanup
AUDIT_LOG_RETENTION_DAYS=90
SUSPICIOUS_ACTIVITY_WINDOW_HOURS=24
FAILED_LOGIN_WINDOW_MINUTES=15

# Activity Tracking
ACTIVITY_WINDOW_DAYS=30

# 2FA Configuration
TOTP_DIGITS=6
TOTP_PERIOD_SECONDS=30
BACKUP_CODES_COUNT=10
BACKUP_CODE_LENGTH=8

# CORS
CORS_CREDENTIALS=true

# Security Headers
SECURITY_HSTS_MAX_AGE=31536000

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_ATTEMPTS=100
OTP_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/auth-service.log
ENABLE_FILE_LOGGING=false

# Health check
HEALTH_CHECK_INTERVAL=30000

# App Info
APP_NAME=ApexArenas

# Encryption
ENCRYPTION_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Idempotency
IDEMPOTENCY_TTL=3600

# Validation rules
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=128
MIN_NAME_LENGTH=2
MAX_NAME_LENGTH=50

# Email Configuration
RESEND_API_KEY=
EMAIL_FROM_NOREPLY=your noreply email address
EMAIL_FROM_SUPPORT=your support email address
EMAIL_ENABLED=true
EMAIL_REPLY_TO=your support email address

# Waitlist
WAITLIST_PAYMENT_WINDOW_MINUTES=15
